REDDIT_USER_AGENT=web:ms-lending-demo:1.0 (by /u/ms-lending)

# Yelp Fusion (API key, read-only)
YELP_API_KEY=

# ---------- App data backend (Supabase) ----------
# Browser client — safe to ship; Row-Level Security protects the data:
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Server-only (Vercel functions, migrations, admin) — NEVER expose to the browser:
SUPABASE_SERVICE_ROLE_KEY=
# KMS key the server function uses to envelope-encrypt SSN/DOB before insert:
PII_KMS_KEY_ID=
